generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER") // 'USER' or 'ADMIN'
  createdAt DateTime @default(now())
  
  applications Application[]
  policies     Policy[]
  payments     Payment[]
  claims       Claim[]
}

model Plan {
  id              String   @id @default(uuid())
  name            String
  description     String
  category        String
  premium         String
  ageEligibility  String
  policyTerm      String
  sumAssuredRange String
  status          String   @default("Active")
  createdAt       DateTime @default(now())

  applications Application[]
  policies     Policy[]
}

model Application {
  id            String   @id @default(uuid())
  appReference  String   @unique
  userId        String
  planId        String
  status        String   @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  formData      String   // JSON stringified data
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])
}

model Policy {
  id            String   @id @default(uuid())
  policyNo      String   @unique
  userId        String
  planId        String
  status        String   @default("Active") // policy ka status (Active, Expired, Matured, Cancelled)
  startDate     DateTime @default(now())
  endDate       DateTime
  premium       Float    // har mahine/saal kitna dena hai
  totalAmount   Float    // total kitna paisa milega
  nextDueDate   DateTime // agli kist kab deni hai
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]
  claims   Claim[]
}

model Payment {
  id         String   @id @default(uuid())
  txnId      String   @unique
  policyId   String
  userId     String
  amount     Float
  payDate    DateTime @default(now())
  status     String   @default("Success") // Success, Failed, ya Pending
  payMode    String   // user ne kaise pay kiya (UPI, Card, NetBanking)
  createdAt  DateTime @default(now())

  policy Policy @relation(fields: [policyId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model Claim {
  id           String    @id @default(uuid())
  claimId      String    @unique
  policyId     String
  userId       String
  claimReason  String    // kis liye claim kiya (Maturity, Death, Cancel)
  amount       Float
  status       String    @default("Pending") // Pending, Approved, ya Rejected
  description  String
  documentUrl  String?   // agar koi document upload kiya ho
  applyDate    DateTime  @default(now())
  solveDate    DateTime? // claim kab solve hua

  policy Policy @relation(fields: [policyId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}
